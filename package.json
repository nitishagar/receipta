{
  "name": "receipta",
  "private": true,
  "version": "0.1.0",
  "description": "Tamper-evident receipts for every AI decision. Ed25519-signed, hash-chained, offline-verifiable.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.4.0",
  "author": {
    "name": "Nitish Agarwal",
    "url": "https://github.com/nitishagar"
  },
  "homepage": "https://github.com/nitishagar/receipta",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitishagar/receipta.git"
  },
  "bugs": {
    "url": "https://github.com/nitishagar/receipta/issues"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm --filter @receipta/core --filter @receipta/design-tokens run build && pnpm --filter @receipta/openai --filter @receipta/anthropic --filter @receipta/vercel --filter @receipta/cli run build",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "verify:demo": "pnpm --filter @receipta/core build && node packages/core/scripts/verify-demo.mjs",
    "example": "pnpm build && node examples/quickstart/run.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.10"
  }
}

{
  "name": "@receipta/core",
  "version": "0.1.1",
  "description": "Tamper-evident receipt core: RFC 8785 canonicalization, Ed25519 signing, hash-chained store, offline verify. Zero runtime dependencies.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./canon": {
      "types": "./dist/canon.d.ts",
      "import": "./dist/canon.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./chain": {
      "types": "./dist/chain.d.ts",
      "import": "./dist/chain.js"
    },
    "./trust": {
      "types": "./dist/trust.d.ts",
      "import": "./dist/trust.js"
    },
    "./adapter-support": {
      "types": "./dist/adapter-support.d.ts",
      "import": "./dist/adapter-support.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitishagar/receipta.git",
    "directory": "packages/core"
  },
  "homepage": "https://nitishagar.github.io/receipta/",
  "bugs": {
    "url": "https://github.com/nitishagar/receipta/issues"
  }
}

{
  "name": "@receipta/anthropic",
  "version": "0.2.0",
  "description": "receipta integration for the Anthropic SDK — emits signed, hash-chained receipts for every message.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@receipta/core": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitishagar/receipta.git",
    "directory": "packages/anthropic"
  },
  "homepage": "https://nitishagar.github.io/receipta/",
  "bugs": {
    "url": "https://github.com/nitishagar/receipta/issues"
  }
}
